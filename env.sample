# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o

# Azure Cognitive Search
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_INDEX_NAME=knowledge-mining-index

# Azure Content Understanding
AZURE_CONTENT_UNDERSTANDING_ENDPOINT=

# Microsoft Entra ID (AAD)
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=

# RAG CONFIGURATION

RAG_TOP_K=5
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_ENABLE_RERANKING=false

# STORAGE 

DOCUMENT_STORE_TYPE=memory   # memory | cosmos
VECTOR_STORE_TYPE=memory     # memory | azure_search
PIPELINE_STORE_TYPE=memory   # memory | blob

#Pipeline
PIPELINES_CONFIG_DIR=app/config/use_cases
ENABLE_AUTO_PIPELINE_SELECTION=true
PIPELINE_DEFAULT_TIMEOUT=30

# App
# DATA_DIR=./data

# Azure AI Foundry Agent (for scripts/create_agent.py and scripts/test_agent.py)
AZURE_AI_AGENT_ENDPOINT=
AZURE_AI_AGENT_MODEL=gpt-4o
AZURE_AI_SEARCH_CONNECTION_NAME=km-search-connection


# Azure Storage (for document uploads)
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_CONTAINER=documents

# Azure Cosmos DB 
AZURE_COSMOS_ENDPOINT=
AZURE_COSMOS_DATABASE=km-db

# Azure SQL 
AZURE_SQL_SERVER=
AZURE_SQL_DATABASE=km-db

# External Data Sources (JSON array — auto-connects on startup)
# Supported source_type: fabric, sql, synapse, odbc, azure_search
# auth_method: managed_identity (default) or connection_string
# query_mode: both (default), live, or ingest
#
# Examples:
# DATA_SOURCES=[{"name":"My Fabric Lakehouse","source_type":"fabric","endpoint":"your-server.database.fabric.microsoft.com","database":"your-lakehouse","table_or_query":"your_table"}]
# DATA_SOURCES=[{"name":"SQL Analytics","source_type":"sql","connection_string":"Driver={ODBC Driver 18 for SQL Server};Server=myserver;Database=mydb;Uid=user;Pwd=pass;","table_or_query":"conversations"}]
# DATA_SOURCES=[{"name":"Search Index","source_type":"azure_search","endpoint":"https://your-search.search.windows.net","table_or_query":"your-index-name"}]
DATA_SOURCES=
